{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "passwd",
  "version": "0.1.1",
  "identifier": "app.passwd.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1430",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "passwd",
        "width": 1040,
        "height": 720,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'wasm-unsafe-eval'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb"],
    "category": "Utility",
    "shortDescription": "Standalone offline password vault",
    "longDescription": "A standalone, offline password manager. The vault is a single portable encrypted file you can keep on a USB stick; nothing is sent over the network.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
