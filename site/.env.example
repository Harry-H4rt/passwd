# Copy to .env (git-ignored). Astro inlines PUBLIC_* vars at build time.

# Where the site's "Open vault" / "Create free vault" buttons point.
PUBLIC_VAULT_URL=http://localhost:5173

# Repo / "build from source" links.
PUBLIC_GITHUB_URL=https://github.com/Harry-H4rt/passwd

# Where the desktop app "Download" button points (defaults to
# $PUBLIC_GITHUB_URL/releases/latest).
PUBLIC_RELEASES_URL=https://github.com/Harry-H4rt/passwd/releases/latest
