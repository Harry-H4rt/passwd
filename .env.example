# Copy to .env (git-ignored) for docker compose. Generate strong, STABLE secrets:
#   openssl rand -hex 32

# Signs access tokens (HS256).
PASSWD_JWT_SECRET=

# Mixed into the identifier-blinding HMAC. NEVER change it after launch: rotating
# it orphans every account.
PASSWD_IDENTIFIER_PEPPER=

# Comma-separated CORS allowlist: your web-vault origin(s), e.g.
# https://vault.example.com  (leave empty if the SPA is same-origin via a proxy).
PASSWD_ALLOWED_ORIGINS=

# --- Passkeys / WebAuthn (second factor) ---
# Relying Party ID: the registrable domain of the web vault, HOST ONLY (no scheme,
# no port), e.g. vault.example.com. Passkeys are permanently bound to it, so set it
# once and keep it STABLE. Defaults to "localhost" for local dev.
PASSWD_WEBAUTHN_RP_ID=
# Human-facing name authenticators show during enrollment. Defaults to "passwd".
PASSWD_WEBAUTHN_RP_NAME=
# Comma-separated fully-qualified origins allowed to run passkey ceremonies, e.g.
# https://vault.example.com. Leave empty to reuse PASSWD_ALLOWED_ORIGINS.
PASSWD_WEBAUTHN_RP_ORIGINS=
