# Copy to .env (git-ignored). WXT inlines WXT_* vars into the build, and
# wxt.config.ts reads WXT_API_BASE to set the manifest host_permissions origin.
#
# For a production build, export these so both the code and the manifest match,
# e.g.:  WXT_API_BASE=https://api.example.com WXT_VAULT_URL=https://vault.example.com npm run build

# Backend API origin the extension talks to (also becomes host_permissions).
WXT_API_BASE=http://localhost:8080

# Web vault URL used by the "create an account" link.
WXT_VAULT_URL=http://localhost:5173
