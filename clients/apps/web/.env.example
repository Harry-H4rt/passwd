# Copy to .env (git-ignored). Vite inlines VITE_* vars at build time.

# Backend API origin. Leave empty for same-origin (the dev proxy in dev, or a
# reverse proxy that co-hosts /api with the SPA in prod). Set to the API origin
# when hosting the SPA and API separately, e.g. https://api.example.com
VITE_API_BASE=
