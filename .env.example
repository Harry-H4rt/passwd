# Copy to .env (git-ignored) for docker compose. Generate strong, STABLE secrets:
#   openssl rand -hex 32

# Signs access tokens (HS256).
PASSWD_JWT_SECRET=

# Mixed into the identifier-blinding HMAC. NEVER change it after launch: rotating
# it orphans every account.
PASSWD_IDENTIFIER_PEPPER=

# Comma-separated CORS allowlist: your web-vault origin(s), e.g.
# https://vault.example.com  (leave empty if the SPA is same-origin via a proxy).
PASSWD_ALLOWED_ORIGINS=
