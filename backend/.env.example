# Copy to .env (git-ignored) and adjust. The server reads plain env vars.
PASSWD_ADDR=:8080
PASSWD_ENV=development
# SQLite database path. Use "memory" for a non-durable in-memory store.
PASSWD_DB=data/passwd.db
# Used to sign access tokens (HS256). MUST be a strong random value in prod.
PASSWD_JWT_SECRET=dev-only-insecure-secret-change-me
# Server-side pepper mixed into the identifier-blinding HMAC. MUST be strong and
# STABLE in prod (changing it orphans all accounts). Generate: openssl rand -hex 32
PASSWD_IDENTIFIER_PEPPER=dev-only-insecure-pepper-change-me
# Auth requests per client IP per minute (spam protection; per-account lockout is
# the real brute-force defense). Keep generous for users behind shared NAT.
PASSWD_AUTH_RATELIMIT_PER_MIN=60
