---
import "../styles/global.css";
import Icon from "../components/Icon.astro";
import { VAULT_URL, GITHUB_URL } from "../config";

interface Props {
  title?: string;
  description?: string;
  active?: string;
}

const {
  title = "passwd: zero-knowledge password manager",
  description = "A password manager that literally can't read your passwords. Zero-knowledge, end-to-end encrypted, open source.",
  active = "",
} = Astro.props;

const links = [
  { href: "/features", label: "Features", key: "features" },
  { href: "/security", label: "Security", key: "security" },
  { href: "/faq#download", label: "Download", key: "download" },
  { href: "/faq", label: "FAQ", key: "faq" },
];

const favicon =
  "data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23ee6611' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><rect x='4' y='10' width='16' height='11' rx='2'/><path d='M8 10V7a4 4 0 018 0v3'/></svg>";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href={favicon} />
    <title>{title}</title>
    <script is:inline>
      (function () {
        try {
          const saved = localStorage.getItem("theme");
          const dark = saved ? saved === "dark" : matchMedia("(prefers-color-scheme: dark)").matches;
          if (dark) document.documentElement.dataset.theme = "dark";
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <header class="nav">
      <div class="container nav-inner">
        <a class="brand" href="/"><Icon name="lock" size={20} />passwd</a>
        <nav class="nav-links">
          {links.map((l) => <a href={l.href} class={active === l.key ? "active" : ""}>{l.label}</a>)}
        </nav>
        <div class="nav-right">
          <button class="theme-toggle" id="themeToggle" type="button" aria-label="Toggle dark mode">
            <svg class="sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
            <svg class="moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1111.2 3a7 7 0 009.8 9.8z"/></svg>
          </button>
          <a class="btn btn-primary" href={VAULT_URL}>Open vault</a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container footer-inner">
        <p class="muted">Zero-knowledge password manager. Your keys never leave your device.</p>
        <div class="footer-links">
          <a href="/features">Features</a>
          <a href="/security">Security</a>
          <a href="/faq#download">Download</a>
          <a href="/faq">FAQ</a>
          <a href={GITHUB_URL}>GitHub</a>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById("themeToggle");
      btn?.addEventListener("click", () => {
        const isDark = document.documentElement.dataset.theme === "dark";
        if (isDark) {
          delete document.documentElement.dataset.theme;
          localStorage.setItem("theme", "light");
        } else {
          document.documentElement.dataset.theme = "dark";
          localStorage.setItem("theme", "dark");
        }
      });
    </script>
  </body>
</html>
