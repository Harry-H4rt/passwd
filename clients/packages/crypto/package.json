{
  "name": "@passwd/crypto",
  "version": "0.0.0",
  "description": "Zero-knowledge crypto for passwd. Runs in browsers (web vault + extension) and Node. The server never imports this.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "node --import tsx --test src/*.test.ts",
    "typecheck": "tsc --noEmit",
    "gen-vectors": "node --import tsx scripts/gen-vectors.ts"
  },
  "dependencies": {
    "hash-wasm": "^4.11.0"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "~5.6.3",
    "@types/node": "^20.11.0"
  }
}
